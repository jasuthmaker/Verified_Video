# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Nvidia NIM Configuration (Phase 2)
VITE_NIM_API_KEY=your-nim-api-key
VITE_NIM_API_URL=https://api.nima.ai/v1

# App Configuration
VITE_APP_ENV=development
VITE_APP_NAME=Verified Video
VITE_APP_URL=http://localhost:5173

# Feature Flags
VITE_ENABLE_NIM_ANOMALY=false
VITE_ENABLE_LIVENESS_CHECKS=false
VITE_ENABLE_DEVICE_FINGERPRINT=false

# Logging
VITE_LOG_LEVEL=debug
